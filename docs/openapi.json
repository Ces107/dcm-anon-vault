{
  "openapi": "3.1.0",
  "info": {
    "title": "dcm-anon-vault",
    "description": "Hosted single-tenant DICOM pseudonymization API. Wraps the dcm-anon engine (PS3.15 Basic Confidentiality Profile).",
    "version": "0.3.0"
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health",
        "description": "Return service health and version. 503 if the DB SELECT 1 fails.",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/metrics": {
      "get": {
        "summary": "Metrics",
        "description": "Expose Prometheus metrics. No auth \u2014 scrape-only endpoint.\n\nMount behind a private network or an auth proxy in production\n(k8s NetworkPolicy / Fly internal port). The endpoint emits only\ncounters; no PHI or secret material.",
        "operationId": "metrics_metrics_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/v1/anonymize": {
      "post": {
        "summary": "Anonymize",
        "description": "Pseudonymize uploaded DICOM files (PS3.15 Basic Profile).\n\nReturns a ZIP archive of the scrubbed DICOMs. Rate-limits free-tier\ncustomers to 50 files / UTC calendar month. Rejects files declaring\n``BurnedInAnnotation == YES`` (no Clean Pixel Data Option).",
        "operationId": "anonymize_v1_anonymize_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_anonymize_v1_anonymize_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/billing/checkout-session": {
      "post": {
        "summary": "Create Checkout Session",
        "description": "Create a Stripe Checkout session for a Pro/Annual upgrade.",
        "operationId": "create_checkout_session_v1_billing_checkout_session_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CheckoutRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheckoutResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/billing/webhook": {
      "post": {
        "summary": "Stripe Webhook",
        "description": "Handle Stripe webhook events. Signature is mandatory.",
        "operationId": "stripe_webhook_v1_billing_webhook_post",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object",
                  "title": "Response Stripe Webhook V1 Billing Webhook Post"
                }
              }
            }
          }
        }
      }
    },
    "/v1/usage": {
      "get": {
        "summary": "Usage",
        "description": "Return tier, files used this UTC month, monthly quota, and reset time.",
        "operationId": "usage_v1_usage_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UsageResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/audit/verify": {
      "get": {
        "summary": "Audit Verify",
        "description": "Walk the anonymize-event hash chain. Returns OK or first broken id.",
        "operationId": "audit_verify_v1_audit_verify_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuditVerifyResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/webhooks": {
      "get": {
        "summary": "List Webhooks",
        "description": "List the calling customer's registered webhook URLs.",
        "operationId": "list_webhooks_v1_webhooks_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/WebhookResponse"
                  },
                  "type": "array",
                  "title": "Response List Webhooks V1 Webhooks Get"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Register Webhook",
        "description": "Register a webhook URL for ``anonymize.completed`` notifications.",
        "operationId": "register_webhook_v1_webhooks_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebhookRegistration"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WebhookResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/webhooks/deadletter": {
      "get": {
        "summary": "List Deadletter",
        "description": "Admin view of failed webhook deliveries (deadletter queue).",
        "operationId": "list_deadletter_v1_webhooks_deadletter_get",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 100,
              "title": "Limit"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DeadletterRow"
                  },
                  "title": "Response List Deadletter V1 Webhooks Deadletter Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/admin/retention/sweep": {
      "post": {
        "summary": "Trigger Retention Sweep",
        "description": "Run the retention sweep for all customers; return per-tenant counts.\n\nIdempotent; safe to run on a schedule (cron / k8s CronJob).",
        "operationId": "trigger_retention_sweep_v1_admin_retention_sweep_post",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RetentionResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AuditVerifyResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          },
          "first_broken_id": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "First Broken Id"
          }
        },
        "type": "object",
        "required": [
          "status"
        ],
        "title": "AuditVerifyResponse"
      },
      "Body_anonymize_v1_anonymize_post": {
        "properties": {
          "files": {
            "items": {
              "type": "string",
              "contentMediaType": "application/octet-stream"
            },
            "type": "array",
            "title": "Files"
          }
        },
        "type": "object",
        "required": [
          "files"
        ],
        "title": "Body_anonymize_v1_anonymize_post"
      },
      "CheckoutRequest": {
        "properties": {
          "success_url": {
            "type": "string",
            "title": "Success Url"
          },
          "cancel_url": {
            "type": "string",
            "title": "Cancel Url"
          },
          "plan": {
            "type": "string",
            "title": "Plan",
            "default": "monthly"
          },
          "customer_email": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Customer Email"
          }
        },
        "type": "object",
        "required": [
          "success_url",
          "cancel_url"
        ],
        "title": "CheckoutRequest"
      },
      "CheckoutResponse": {
        "properties": {
          "checkout_url": {
            "type": "string",
            "title": "Checkout Url"
          },
          "session_id": {
            "type": "string",
            "title": "Session Id"
          }
        },
        "type": "object",
        "required": [
          "checkout_url",
          "session_id"
        ],
        "title": "CheckoutResponse"
      },
      "DeadletterRow": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "customer_id": {
            "type": "integer",
            "title": "Customer Id"
          },
          "url": {
            "type": "string",
            "title": "Url"
          },
          "event_type": {
            "type": "string",
            "title": "Event Type"
          },
          "last_status": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Last Status"
          },
          "last_error": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Last Error"
          },
          "attempts": {
            "type": "integer",
            "title": "Attempts"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "customer_id",
          "url",
          "event_type",
          "last_status",
          "last_error",
          "attempts",
          "created_at"
        ],
        "title": "DeadletterRow"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          },
          "version": {
            "type": "string",
            "title": "Version"
          }
        },
        "type": "object",
        "required": [
          "status",
          "version"
        ],
        "title": "HealthResponse"
      },
      "RetentionResponse": {
        "properties": {
          "swept": {
            "type": "integer",
            "title": "Swept"
          },
          "rows": {
            "items": {
              "$ref": "#/components/schemas/RetentionRow"
            },
            "type": "array",
            "title": "Rows"
          }
        },
        "type": "object",
        "required": [
          "swept",
          "rows"
        ],
        "title": "RetentionResponse"
      },
      "RetentionRow": {
        "properties": {
          "customer_id": {
            "type": "integer",
            "title": "Customer Id"
          },
          "retention_days": {
            "type": "integer",
            "title": "Retention Days"
          },
          "events_deleted": {
            "type": "integer",
            "title": "Events Deleted"
          },
          "deadletter_deleted": {
            "type": "integer",
            "title": "Deadletter Deleted"
          }
        },
        "type": "object",
        "required": [
          "customer_id",
          "retention_days",
          "events_deleted",
          "deadletter_deleted"
        ],
        "title": "RetentionRow"
      },
      "UsageResponse": {
        "properties": {
          "tier": {
            "type": "string",
            "title": "Tier"
          },
          "files_used_mtd": {
            "type": "integer",
            "title": "Files Used Mtd"
          },
          "quota": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Quota"
          },
          "reset_at": {
            "type": "string",
            "title": "Reset At"
          }
        },
        "type": "object",
        "required": [
          "tier",
          "files_used_mtd",
          "quota",
          "reset_at"
        ],
        "title": "UsageResponse"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      },
      "WebhookRegistration": {
        "properties": {
          "url": {
            "type": "string",
            "maxLength": 512,
            "minLength": 8,
            "title": "Url"
          },
          "secret": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 128
              },
              {
                "type": "null"
              }
            ],
            "title": "Secret"
          }
        },
        "type": "object",
        "required": [
          "url"
        ],
        "title": "WebhookRegistration"
      },
      "WebhookResponse": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "url": {
            "type": "string",
            "title": "Url"
          },
          "active": {
            "type": "boolean",
            "title": "Active"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "url",
          "active",
          "created_at"
        ],
        "title": "WebhookResponse"
      }
    }
  }
}
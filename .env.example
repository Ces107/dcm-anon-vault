# dcm-anon-vault environment variables
# Copy this to .env and fill in real values. NEVER commit .env.

# Comma-separated customer API keys in the form customer_id:key
# Example: acme:key_abc123,beta_corp:key_xyz789
DCM_API_KEYS=demo:REPLACE_ME

# Stripe test-mode keys (get from https://dashboard.stripe.com/test/apikeys)
STRIPE_TEST_KEY=REPLACE_ME
STRIPE_PRICE_ID=REPLACE_ME

# Stripe webhook signing secret (from Stripe CLI or dashboard)
STRIPE_WEBHOOK_SECRET=REPLACE_ME

# SQLAlchemy database URL (SQLite by default; use absolute path on Fly.io with mount)
DCM_DB_URL=sqlite:///./vault.db
